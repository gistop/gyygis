# =============================================================================
# gyygis — monorepo 根 .gitignore
# 规则适用于仓库根目录及 packages/* 下未来新增的子项目（不忽略 packages 本身）
# =============================================================================

# -----------------------------------------------------------------------------
# 依赖（根与各 package 内均忽略；锁文件请提交：pnpm-lock.yaml / package-lock.json 等）
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# 包管理器日志（锁文件不要忽略）
# -----------------------------------------------------------------------------
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# 构建产物 / 框架输出（各子项目常见目录名）
# -----------------------------------------------------------------------------
dist/
dist-ssr/
build/
# pure-admin-thin：此处的 build/ 是 Vite 配置脚本（plugins / optimize / utils），不是通用构建产物目录
!packages/gyygis-admin/build/
!packages/gyygis-admin/build/**
out/
.next/
.nuxt/
.output/
.turbo/
storybook-static/

# -----------------------------------------------------------------------------
# 打包器与工具缓存
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# Vite（含子项目）
**/.vite/
.vite-temp/

# -----------------------------------------------------------------------------
# 测试与覆盖率
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# 环境变量：忽略本机/密钥覆盖文件；模板可保留 .env.example
# 若某子项目将非敏感默认写入 .env 并需入库，请勿在此处添加 /.env 全忽略
# -----------------------------------------------------------------------------
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local

# -----------------------------------------------------------------------------
# 操作系统
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE / 编辑器（如需共享 .vscode 团队配置，可删除下一行或改为白名单）
# -----------------------------------------------------------------------------
.idea/
*.swp
*.swo
*.sublime-*

# -----------------------------------------------------------------------------
# 杂项
# -----------------------------------------------------------------------------
*.log
*.tgz
.temp/
tmp/
temp/
