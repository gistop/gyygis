# Docker Compose 使用本文件：在 deploy 目录执行 cp .env.example .env 后填写真实值。
# api 服务的 env_file 指向本目录的 .env；compose 中 ${变量} 也会从本目录 .env 读取。
# 勿提交 .env（见仓库根 .gitignore）。公网部署请把 FRONTEND_DOMAIN 改为管理端真实地址，并在 OSS Bucket CORS 中允许该来源。

# =============================================================================
# gyygis-server（api 容器）— 与 packages/gyygis-server 读取的环境变量一致
# =============================================================================

# ---------- 天地图（必填）----------
# 申请：https://lbs.tianditu.gov.cn/
TIANDITU_KEY=your_tianditu_key_here

# Key 类型（默认留空或不写 = 服务端 Key）
# - 服务端 Key：须在控制台配置「调用方公网 IP」白名单；勿设 TIANDITU_CLIENT_MODE=browser
# - 浏览器端 Key：设 TIANDITU_CLIENT_MODE=browser，并配置下方 Referer 白名单
# TIANDITU_CLIENT_MODE=browser

# 仅浏览器端 Key 需要：发给天地图的 Referer（须与白名单一致）
FRONTEND_DOMAIN=http://localhost:3000

# 容器内 api 监听端口（compose 中固定为 3000，一般无需改）
PORT=3000

# 第三方地图瓦片：true=仅用户自备 key（正式上线）；留空或 false=允许管理员代填作为回退
# WEB_MAP_TILES_REQUIRE_USER_KEY=true

# ---------- 阿里云 OSS 浏览器直传（STS，可选；未配置完整时 POST /api/oss/sts-credentials 返回 503）----------
# 须在 OSS 控制台该 Bucket「跨域设置」中允许管理端来源，否则浏览器 PUT 会被 CORS 拦截。
# RAM 用户（供服务端调用 STS；勿提交真实密钥到仓库）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
# RAM 角色 ARN，如 acs:ram::1234567890123456:role/oss-upload-role
ALIYUN_OSS_ROLE_ARN=
ALIYUN_OSS_BUCKET=
# OSS Region，须与控制台一致，如 oss-cn-hangzhou
ALIYUN_OSS_REGION=oss-cn-hangzhou
# STS 接入地域（一般取 bucket 地域中的段，如 cn-hangzhou）
ALIYUN_STS_REGION=cn-hangzhou
# 上传对象 key 前缀（须与发布接口校验一致）
ALIYUN_OSS_UPLOAD_PREFIX=uploads/
# 临时凭证有效期（秒），900～43200
ALIYUN_STS_DURATION_SECONDS=3600

# ---------- 管理端「数据」页：从 OSS 读 CSV → PostGIS → GeoServer 发布 ----------
# Docker Compose 已为 api 注入 POSTGRES_HOST、POSTGRES_PORT、GEOSERVER_INTERNAL_URL 等；
# 以下 POSTGRES_* / GEOSERVER_ADMIN_* 供 postgis、geoserver、api 共用（compose 变量替换）。
# 若仅在本地直接 pnpm dev 跑 server，请在 packages/gyygis-server/.env 中自行填写等同项。
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=geodb
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver
# （可选）若 GeoServer REST 账号与上面不同，可在 compose 外扩展；默认 api 使用 GEOSERVER_ADMIN_* 作为 REST 账号。

# =============================================================================
# Docker Compose 栈（宿主机端口与其它服务）
# =============================================================================

API_PORT=3000
# 以下端口变量在「子路径访问」模式下不再需要对外放行
ADMIN_PORT=8081
VIEW_PORT=8082
CORE_PORT=8083
POSTGIS_PORT=5432
PGADMIN_PORT=5050
NGINX_HTTP_PORT=80

# pgAdmin 初始登录（首次启动）
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
