# 复制为 .env 后填写：cp .env.example .env

# 天地图（必填，与 packages/gyygis-server/.env.example 一致）
TIANDITU_KEY=your_tianditu_key_here

# 服务端监听端口（容器内固定 3000；宿主机映射见 API_PORT）
PORT=3000

# 可选：浏览器端 Key 相关（见服务端文档）
# TIANDITU_CLIENT_MODE=browser
# FRONTEND_DOMAIN=https://your-domain

# 宿主机映射（修改则浏览器访问端口随之变化）
API_PORT=3000
ADMIN_PORT=8081
VIEW_PORT=8082
CORE_PORT=8083
