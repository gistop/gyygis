# 天地图 API Key（必填）
# 请到 https://lbs.tianditu.gov.cn/ 申请
# 开发环境下 .env 会覆盖同名系统变量；勿在 Windows 环境变量里长期保留占位符 TIANDITU_KEY。
TIANDITU_KEY=your_tianditu_key_here

# Key 类型（默认留空或不写 = 服务端 Key）
# - 服务端 Key：须在控制台配置「调用方公网 IP」白名单；勿设 TIANDITU_CLIENT_MODE=browser
# - 浏览器端 Key：设 TIANDITU_CLIENT_MODE=browser，并配置下方 Referer 白名单
# TIANDITU_CLIENT_MODE=browser

# 仅浏览器端 Key 需要：发给天地图的 Referer（须与白名单一致）
FRONTEND_DOMAIN=http://localhost:3000

# 服务端口
PORT=3000

# ---------- 阿里云 OSS 浏览器直传（STS，可选；未配置时 POST /api/oss/sts-credentials 返回 503）----------
# 浏览器直传时须在 OSS 控制台该 Bucket「跨域设置」中允许管理端来源（如 http://localhost:8848），否则 PUT 会被 CORS 拦截。
# RAM 用户（供服务端调用 STS，勿提交到仓库）
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# RAM 角色 ARN，如 acs:ram::1234567890123456:role/oss-upload-role
# ALIYUN_OSS_ROLE_ARN=
# Bucket 名称
# ALIYUN_OSS_BUCKET=
# OSS Region，须与控制台一致，如 oss-cn-hangzhou
# ALIYUN_OSS_REGION=oss-cn-hangzhou
# STS 接入地域（一般取 bucket 地域中的段，如 cn-hangzhou）
# ALIYUN_STS_REGION=cn-hangzhou
# 上传对象 key 前缀
# ALIYUN_OSS_UPLOAD_PREFIX=uploads/
# 临时凭证有效期（秒），900～43200
# ALIYUN_STS_DURATION_SECONDS=3600
